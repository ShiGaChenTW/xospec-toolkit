# x.ospec Generator 預設值
# 放在專案目錄或 $HOME 下，檔名為 .xospec-generator.yml
# 這些值會在 TUI 中預填，可在表單中覆寫

project_name: my-project
capabilities: auth, billing
target_user: End users
user_problem: Users cannot complete the core task efficiently
feature_why: It delivers the first meaningful user value
overwrite: "no"
enable_superpowers: "yes"
git_init: "yes"
